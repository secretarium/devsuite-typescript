{
    "private": true,
    "name": "floo-ui",
    "description": "",
    "license": "",
    "scripts": {
        "build": "npx remix build",
        "dev": "npx remix dev",
        "start": "cross-env NODE_ENV=development ts-node --require tsconfig-paths/register ./src/server.ts",
        "postinstall": "npx remix setup node",
        "prisma-generate": "prisma generate --schema ./src/prisma/schema.prisma",
        "prisma-generate-watch": "yarn run prisma-generate --watch",
        "prisma-push": "prisma db push --schema ./src/prisma/schema.prisma",
        "prisma-seed": "prisma db seed",
        "prisma-studio": "prisma studio --schema ./src/prisma/schema.prisma",
        "serve": "npx remix-serve build",
        "tailwind-generate": "tailwindcss -c ./tailwind.config.js -o ./src/app/styles/tailwind.css",
        "tailwind-generate-watch": "yarn run tailwind-generate -w"
    },
    "dependencies": {
        "@prisma/client": "*",
        "@remix-run/express": "*",
        "@remix-run/node": "*",
        "@remix-run/serve": "*",
        "argon2": "*",
        "encoding": "*",
        "react": "*",
        "react-dom": "*",
        "remix": "*"
    },
    "engines": {
        "node": ">=14"
    },
    "sideEffects": false,
    "prisma": {
        "seed": "ts-node --require tsconfig-paths/register ./src/prisma/seed.ts"
    },
    "browserslist": "defaults, not IE 11"
}